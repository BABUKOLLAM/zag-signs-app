generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("NEON_DATABASE_URL")
  directUrl = env("NEON_DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Branch {
  TVM
  KTYM
  EKM
  CLT
}

enum UserRole {
  MD
  AVP
  BUSINESS_MANAGER
  SALES_EXECUTIVE
  CRES
  PRODUCTION
  DESIGNER
  ACCOUNTS
  HR
  IT_ADMIN
  CONSULTANT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  COLD_CALL
  REFERRAL
  WALK_IN
  WEBSITE
  SOCIAL_MEDIA
  EXHIBITION
  OTHER
}

enum OpportunityStage {
  QUALIFICATION
  PROPOSAL_SENT
  NEGOTIATION
  VERBAL_COMMITMENT
  CLOSED_WON
  CLOSED_LOST
}

enum QuotationStatus {
  DRAFT
  SENT
  EMAIL
  WHATSAPP
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  READY
  INSTALLED
  INVOICED
  COLLECTED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalStatus {
  SUBMITTED
  MANAGER_APPROVED
  AVP_APPROVED
  MD_APPROVED
}

enum VisitType {
  SALES_CALL
  SITE_SURVEY
  INSTALLATION
  SERVICE_COMPLAINT
  COLLECTION
  FOLLOW_UP
}

enum VisitOutcome {
  POSITIVE
  ORDER_EXPECTED
  FOLLOW_UP_NEEDED
  NOT_INTERESTED
  COMPLETED
}

enum PaymentMode {
  CASH
  CHEQUE
  NEFT
  UPI
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WOTicketSource {
  WALK_IN
  PHONE
  WHATSAPP
  EMAIL
  QUOTATION
  OTHER
}

enum WOTicketStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  HALF_DONE
  DONE
  BILLED
  CANCELLED
}

enum WOTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── CORE AUTH ────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  password       String
  role           UserRole
  branch         Branch?   // null = all branches (MD, AVP, HR, IT_ADMIN)
  phone          String?
  isActive       Boolean   @default(true)
  status         String    @default("PENDING") // PENDING | ACTIVE | INACTIVE
  approvalToken  String?   @unique
  tokenExpiry    DateTime?
  reportingToId  String?
  reportingTo    User?     @relation("Hierarchy", fields: [reportingToId], references: [id])
  reportees      User[]    @relation("Hierarchy")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  permission           UserPermission?
  proposedQuotations   Quotation[] @relation("QuotationProposedBy")
  assignedLeads        Lead[]      @relation("AssignedTo")
  createdLeads       Lead[]      @relation("CreatedBy")
  salesOrders        SalesOrder[]
  assignedTasks      Task[]      @relation("TaskAssignee")
  createdTasks       Task[]      @relation("TaskCreator")
  fieldVisits        FieldVisit[]
  dars               DAR[]
  wwrs               WWR[]
  mwrs               MWR[]
  documents          Document[]
  assignedComplaints Complaint[] @relation("ComplaintAssignee")
  attendance         Attendance[]
  leaveRequests      LeaveRequest[]
  notifications      Notification[]
  auditLogs          AuditLog[]

  assignedTickets    WorkOrderTicket[] @relation("TicketDesigner")
  createdTickets     WorkOrderTicket[] @relation("TicketCreator")
  ticketEvents       WorkOrderTicketEvent[]

  // Sales Module Relations
  activityLogs       ActivityLog[] @relation("ActivityLogs")
  claimsSubmitted    SalesClaim[] @relation("SalesClaimsSubmitted")
  claimApprovals     ClaimApprovalHistory[]
  salesTargets       SalesTarget[]
  fjpSubmissions     FJP[] @relation("FJPSubmissions")
  expenseSubmissions ExpenseReport[] @relation("ExpenseSubmissions")
  expenseApprovals   ExpenseApproval[] @relation("ExpenseApprovals")

  // Production Phase 2 Relations
  machineSchedulesAsOperator MachineSchedule[]
  qualityCheckpointsAsInspector QualityCheckpoint[]
  productionRejectionsApprovals ProductionRejection[]

  @@map("users")
}

model UserPermission {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  modules     String[]
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("user_permissions")
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model Lead {
  id           String     @id @default(cuid())
  leadNo       String     @unique
  name         String
  company      String?
  phone        String
  email        String?
  branch       Branch
  status       LeadStatus @default(NEW)
  source       LeadSource @default(OTHER)
  value        Float      @default(0)
  notes        String?
  followUpDate DateTime?
  closedAt     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdById  String?
  createdBy    User?   @relation("CreatedBy", fields: [createdById], references: [id])

  opportunities Opportunity[]
  quotations    Quotation[]
  activityLogs  ActivityLog[]

  @@map("leads")
}

model Customer {
  id                 String   @id @default(cuid())
  customerNo         String   @unique
  name               String
  company            String
  phone              String
  email              String?
  address            String?
  branch             Branch
  gstNo              String?
  creditLimit        Float    @default(0)
  outstandingBalance Float    @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  quotations   Quotation[]
  salesOrders  SalesOrder[]
  complaints   Complaint[]
  collections  Collection[]
  fieldVisits  FieldVisit[]
  invoices     Invoice[]
  tickets      WorkOrderTicket[]
  activityLogs ActivityLog[]

  @@map("customers")
}

model Opportunity {
  id            String           @id @default(cuid())
  title         String
  stage         OpportunityStage @default(QUALIFICATION)
  probability   Int              @default(20)
  value         Float
  branch        Branch
  expectedClose DateTime?
  notes         String?
  closedAt      DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  activityLogs ActivityLog[]

  @@map("opportunities")
}

// ─── QUOTATIONS & ORDERS ──────────────────────────────────────────────────────

model Quotation {
  id                  String          @id @default(cuid())
  quotationNo         String          @unique
  status              QuotationStatus @default(DRAFT)
  subtotal            Float
  taxRate             Float           @default(0)
  tax                 Float           @default(0)
  discount            Float           @default(0)
  total               Float
  validUntil          DateTime?
  terms               String?
  notes               String?
  salutation          String?         // M/s, Mr., Ms., Dr., Prof., Adv.
  attentionSalutation String?         // salutation for Kind Attn person
  attentionName       String?         // name for Kind Attn line
  branch              String?         // branch code (TVM/KTM/EKM/CLT/HO)
  proposedById        String?
  clientCode          String?         // auto-generated abbreviation e.g. BMH
  parentQuotationId   String?         // root quotation for revisions
  revisionNote        String?         // reason for this revision
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  customerId      String?
  customer        Customer?  @relation(fields: [customerId], references: [id])
  leadId          String?
  lead            Lead?      @relation(fields: [leadId], references: [id])
  proposedBy      User?      @relation("QuotationProposedBy", fields: [proposedById], references: [id])
  parentQuotation Quotation? @relation("QuotationRevisions", fields: [parentQuotationId], references: [id], onDelete: SetNull)
  revisions       Quotation[] @relation("QuotationRevisions")

  items       QuotationItem[]
  salesOrders SalesOrder[]
  invoices    Invoice[]
  tickets     WorkOrderTicket[]

  @@map("quotations")
}

model QuotationItem {
  id          String @id @default(cuid())
  description String
  qty         Float  @default(1)
  unit        String @default("Nos")
  unitPrice   Float
  total       Float

  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

model SalesOrder {
  id           String      @id @default(cuid())
  orderNo      String      @unique
  status       OrderStatus @default(DRAFT)
  orderDate    DateTime    @default(now())
  deliveryDate DateTime?
  totalAmount  Float
  paidAmount   Float       @default(0)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  quotationId String?
  quotation   Quotation? @relation(fields: [quotationId], references: [id])
  createdById String?
  createdBy   User?      @relation(fields: [createdById], references: [id])

  workOrders  WorkOrder[]
  invoices    Invoice[]
  collections Collection[]

  @@map("sales_orders")
}

// ─── OPERATIONS ───────────────────────────────────────────────────────────────

model WorkOrder {
  id          String    @id @default(cuid())
  workOrderNo String    @unique
  description String
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  priority    String    @default("Medium")
  status      String    @default("Pending")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])

  productionLogs ProductionLog[]
  materialConsumptions MaterialConsumption[]
  schedules MachineSchedule[]
  qualityCheckpoints QualityCheckpoint[]
  rejections ProductionRejection[]

  @@map("work_orders")
}

model ProductionLog {
  id               String    @id @default(cuid())
  date             DateTime  @default(now())
  productionOutput String?
  outputQty        Float     @default(0)
  downtimeHours    Float     @default(0)
  downtimeReason   String?
  dispatches       Int       @default(0)
  dispatchDetails  String?
  notes            String?
  createdAt        DateTime  @default(now())

  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@map("production_logs")
}

// ─── INVENTORY ────────────────────────────────────────────────────────────────

model Material {
  id           String   @id @default(cuid())
  name         String
  category     String
  unit         String   @default("Nos")
  currentStock Float    @default(0)
  minimumStock Float    @default(0)
  unitCost     Float    @default(0)
  supplier     String?
  branch       String?  // TVM | KTYM | EKM | CLT | null = all-branch/company stock
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stockMovements StockMovement[]
  consumptions MaterialConsumption[]

  @@index([branch])
  @@map("materials")
}

model StockMovement {
  id        String   @id @default(cuid())
  type      String   // IN / OUT / ADJUSTMENT
  quantity  Float
  reference String?
  notes     String?
  branch    String?  // which branch the movement belongs to
  createdAt DateTime @default(now())

  materialId String
  material   Material @relation(fields: [materialId], references: [id])

  @@index([branch])
  @@map("stock_movements")
}

// Per-branch operational configuration — machine types, hours, contact info
model BranchOperationalSetting {
  id                 String   @id  // TVM, KTYM, EKM, CLT, HO
  displayName        String   @default("")
  address            String   @default("")
  contactName        String   @default("")
  contactPhone       String   @default("")
  startTime          String   @default("09:00")  // HH:MM
  endTime            String   @default("18:00")  // HH:MM
  shiftHours         Float    @default(8)
  machineTypes       String   @default("[]")     // JSON [{type,defaultRate,printTypes,enabled}]
  materialCategories String   @default("[]")     // JSON [category strings active at branch]
  notes              String   @default("")
  updatedAt          DateTime @updatedAt

  @@map("branch_operational_settings")
}

// ─── FINANCE ──────────────────────────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  invoiceNo       String        @unique
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  subtotal        Float         @default(0)
  taxRate         Float         @default(0)
  taxAmount       Float         @default(0)
  discount        Float         @default(0)
  totalAmount     Float
  status          PaymentStatus @default(PENDING)
  notes           String?
  branch          String        @default("HO")
  items           Json          @default("[]")
  customerName    String?
  customerAddress String?
  customerGst     String?
  customerPhone   String?
  salutation      String?
  attentionName   String?
  tallyExported   Boolean       @default(false)
  tallyExportedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])
  quotationId  String?
  quotation    Quotation?  @relation(fields: [quotationId], references: [id])
  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id])

  collections Collection[]

  @@map("invoices")
}

model Collection {
  id             String      @id @default(cuid())
  collectionDate DateTime    @default(now())
  amount         Float
  paymentMode    PaymentMode @default(BANK_TRANSFER)
  reference      String?
  notes          String?
  createdAt      DateTime    @default(now())

  customerId   String?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])
  invoiceId    String?
  invoice      Invoice?    @relation(fields: [invoiceId], references: [id])

  @@map("collections")
}

// ─── PEOPLE & FIELD ───────────────────────────────────────────────────────────

model Complaint {
  id          String            @id @default(cuid())
  complaintNo String            @unique
  subject     String
  description String
  status      ComplaintStatus   @default(OPEN)
  priority    ComplaintPriority @default(MEDIUM)
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  assignedToId String?
  assignedTo   User?     @relation("ComplaintAssignee", fields: [assignedToId], references: [id])

  @@map("complaints")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  relatedTo   String?
  relatedType String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById  String?
  createdBy    User?   @relation("TaskCreator", fields: [createdById], references: [id])

  @@map("tasks")
}

model FieldVisit {
  id           String       @id @default(cuid())
  date         DateTime     @default(now())
  visitType    VisitType
  outcome      VisitOutcome
  customerName String
  location     String?
  startTime    String?
  endTime      String?
  geoTagged    Boolean      @default(false)
  latitude     Float?
  longitude    Float?
  orderValue   Float?
  nextAction   String?
  notes        String?
  createdAt    DateTime     @default(now())

  employeeId String?
  employee   User?     @relation(fields: [employeeId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  @@map("field_visits")
}

// ─── REPORTS ──────────────────────────────────────────────────────────────────

model DAR {
  id                   String   @id @default(cuid())
  date                 DateTime @default(now())
  branch               Branch
  department           String
  customerVisits       Int      @default(0)
  callsMade            Int      @default(0)
  followUpsDone        Int      @default(0)
  ordersBooked         Int      @default(0)
  ordersValue          Float    @default(0)
  collectionsAmount    Float    @default(0)
  travelFrom           String?
  travelTo             String?
  travelKm             Float    @default(0)
  productionOutput     String?
  outputQty            Float    @default(0)
  downtimeHours        Float    @default(0)
  downtimeReason       String?
  dispatches           Int      @default(0)
  dispatchDetails      String?
  accountsCollections  Float    @default(0)
  collectionFrom       String?
  vendorPayments       Float    @default(0)
  vendorDetails        String?
  reconciliationStatus String?
  createdAt            DateTime @default(now())

  employeeId String?
  employee   User?   @relation(fields: [employeeId], references: [id])

  @@map("dars")
}

model WWR {
  id                String         @id @default(cuid())
  weekFrom          DateTime
  weekTo            DateTime
  branch            Branch
  department        String
  weeklyTarget      Float          @default(0)
  weeklyAchievement Float          @default(0)
  challenges        String?
  actionPlan        String?
  escalationsNeeded Boolean        @default(false)
  escalationDetails String?
  approvalStatus    ApprovalStatus @default(SUBMITTED)
  approvedByManager DateTime?
  approvedByAVP     DateTime?
  approvedByMD      DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  employeeId String?
  employee   User?   @relation(fields: [employeeId], references: [id])

  @@map("wwrs")
}

model MWR {
  id                      String         @id @default(cuid())
  month                   Int
  year                    Int
  branch                  Branch
  department              String
  salesTarget             Float?
  salesAchievement        Float?
  conversionPct           Float?
  collectionPct           Float?
  productionAchievement   Float?
  efficiencyPct           Float?
  rejectionCount          Int?
  rejectionReasons        String?
  collectionEfficiencyPct Float?
  outstandingReduction    Float?
  totalCollected          Float?
  approvalStatus          ApprovalStatus @default(SUBMITTED)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  employeeId String?
  employee   User?   @relation(fields: [employeeId], references: [id])

  @@map("mwrs")
}

// ─── DOCUMENTS ────────────────────────────────────────────────────────────────

model Document {
  id          String   @id @default(cuid())
  name        String
  category    String
  fileType    String
  fileSize    String?
  fileUrl     String?
  storageKey  String?
  branch      Branch?
  relatedTo   String?
  relatedType String?
  tags        String[]
  createdAt   DateTime @default(now())

  uploadedById String?
  uploadedBy   User?   @relation(fields: [uploadedById], references: [id])

  @@map("documents")
}

// ─── HR ───────────────────────────────────────────────────────────────────────

model Employee {
  id            String    @id @default(cuid())
  employeeNo    String    @unique
  name          String
  designation   String
  department    String
  branch        Branch
  phone         String?
  email         String?
  dateOfJoining DateTime?
  salary        Float?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  attendance    Attendance[]
  leaveRequests LeaveRequest[]

  @@map("employees")
}

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  status    AttendanceStatus @default(PRESENT)
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])

  @@unique([employeeId, date])
  @@map("attendance")
}

model LeaveRequest {
  id         String      @id @default(cuid())
  leaveType  String
  fromDate   DateTime
  toDate     DateTime
  days       Float
  reason     String?
  status     LeaveStatus @default(PENDING)
  approvedAt DateTime?
  createdAt  DateTime    @default(now())

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])

  @@map("leave_requests")
}

// ─── COMPANY SETTINGS ─────────────────────────────────────────────────────────

model CompanySetting {
  id           String   @id @default("company")
  name         String   @default("ZAG SIGNS")
  tagline      String   @default("Excellence in Signage Solutions")
  address      String   @default("")
  phone        String   @default("")
  email        String   @default("")
  website      String   @default("")
  gstNo        String   @default("")
  panNo        String   @default("")
  logoUrl      String?
  bankName     String   @default("")
  bankBranch   String   @default("")
  accountNo    String   @default("")
  ifscCode     String   @default("")
  accountType  String   @default("Current Account")
  defaultTerms String   @default("")
  validityDays  Int      @default(30)
  paymentQrUrl  String?
  updatedAt     DateTime @updatedAt

  @@map("company_settings")
}

model BranchSetting {
  id           String   @id // branch code: TVM, KTYM, EKM, CLT, HO
  bankName     String   @default("")
  bankBranch   String   @default("")
  accountNo    String   @default("")
  ifscCode     String   @default("")
  accountType  String   @default("Current Account")
  updatedAt     DateTime @updatedAt

  @@map("branch_settings")
}

// ─── ORGANISATIONAL STRUCTURE ─────────────────────────────────────────────────

model Division {
  id          String       @id @default(cuid())
  code        String       @unique  // e.g. "TVM-SALES"
  name        String
  branch      String       // TVM | KTYM | EKM | CLT | HO
  headName    String       @default("")
  headEmail   String       @default("")
  headPhone   String       @default("")
  notes       String       @default("")
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  departments Department[]

  @@index([branch])
  @@map("divisions")
}

model Department {
  id          String   @id @default(cuid())
  name        String
  divisionId  String
  division    Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  headName    String   @default("")
  headEmail   String   @default("")
  headPhone   String   @default("")
  notes       String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([divisionId])
  @@map("departments")
}

// ─── SYSTEM ───────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  tableName String
  recordId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── WORK ORDER TICKETS ───────────────────────────────────────────────────────
// Front-office tickets opened from walk-in / phone / WhatsApp / quotation flow.
// Distinct from `WorkOrder` (production tracking downstream of a SalesOrder).

model WorkOrderTicket {
  id              String           @id @default(cuid())
  ticketNo        String           @unique
  branch          String           @default("HO")
  source          WOTicketSource   @default(WALK_IN)
  status          WOTicketStatus   @default(NEW)
  priority        WOTicketPriority @default(MEDIUM)

  // Customer details (may or may not be linked to Customer record)
  customerId      String?
  customer        Customer?  @relation(fields: [customerId], references: [id])
  customerName    String
  customerPhone   String?
  customerEmail   String?
  customerAddress String?

  // Optional link to upstream quotation
  quotationId     String?
  quotation       Quotation? @relation(fields: [quotationId], references: [id])

  // Work details
  natureOfWork    String      // e.g. Signboard, LED Display, Vehicle Wrap, Hoarding
  description     String
  reference       String?     // PO no, sketch ref, customer's own ref
  attachments     Json        @default("[]")   // [{name,url}]

  // Costing
  estimatedCost   Float       @default(0)
  advancePaid     Float       @default(0)
  balanceDue      Float       @default(0)
  paymentMode     String?     // Cash, NEFT, UPI, Cheque, On Delivery

  // Timeline
  receivedAt      DateTime    @default(now())
  expectedAt      DateTime?
  assignedAt      DateTime?
  startedAt       DateTime?
  halfDoneAt      DateTime?
  completedAt     DateTime?
  billedAt        DateTime?

  // Designer assignment
  assignedDesignerId String?
  assignedDesigner   User?    @relation("TicketDesigner", fields: [assignedDesignerId], references: [id])

  // Status notes
  halfDoneReason   String?
  designerRemarks  String?
  closingNotes     String?

  // Tracking
  createdById      String?
  createdBy        User?      @relation("TicketCreator", fields: [createdById], references: [id])

  events           WorkOrderTicketEvent[]

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([branch, status])
  @@index([assignedDesignerId, status])
  @@map("work_order_tickets")
}

model WorkOrderTicketEvent {
  id          String         @id @default(cuid())
  ticketId    String
  ticket      WorkOrderTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromStatus  WOTicketStatus?
  toStatus    WOTicketStatus
  note        String?
  actorId     String?
  actor       User?          @relation(fields: [actorId], references: [id])
  createdAt   DateTime       @default(now())

  @@index([ticketId, createdAt])
  @@map("work_order_ticket_events")
}

// ─── SALES MODULE ──────────────────────────────────────────────────────────────
// Activity tracking, claims management, sales targets

model ActivityLog {
  id                String   @id @default(cuid())
  activityNo        String   @unique
  type              String   // CALL, VISIT, EMAIL, FOLLOW_UP, OTHER
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  leadId            String?
  lead              Lead? @relation(fields: [leadId], references: [id])
  opportunityId     String?
  opportunity       Opportunity? @relation(fields: [opportunityId], references: [id])
  userId            String
  user              User @relation("ActivityLogs", fields: [userId], references: [id])
  startTime         DateTime
  endTime           DateTime?
  duration          Int?     // minutes
  purpose           String?
  outcome           String?
  nextActionRequired Boolean  @default(false)
  nextActionDate    DateTime?
  nextActionDescription String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reminders         FollowUpReminder[]

  @@index([userId, createdAt])
  @@index([customerId])
  @@index([leadId])
  @@index([opportunityId])
  @@map("activity_logs")
}

model FollowUpReminder {
  id                String   @id @default(cuid())
  activityLogId     String
  activityLog       ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)
  reminderDate      DateTime
  reminderType      String   // CALL, EMAIL, VISIT, VISIT_IF_NO_RESPONSE
  isDone            Boolean  @default(false)
  completedAt       DateTime?
  completedNotes    String?
  createdAt         DateTime @default(now())

  @@index([reminderDate])
  @@index([activityLogId])
  @@map("follow_up_reminders")
}

model SalesClaim {
  id                String   @id @default(cuid())
  claimNo           String   @unique
  claimType         String   // INCENTIVE, TRAVEL, MEETING_EXPENSE, CHARGEBACK
  claimReason       String
  amount            Float
  submittedByUserId String
  submittedBy       User @relation("SalesClaimsSubmitted", fields: [submittedByUserId], references: [id])
  submissionWindow  String   // e.g., "2026-05"
  submittedDate     DateTime @default(now())
  status            String   @default("DRAFT")  // DRAFT, SUBMITTED, MANAGER_REVIEW, MANAGER_APPROVED, AVP_REVIEW, AVP_APPROVED, MD_FINAL_REVIEW, APPROVED, REJECTED
  supportingDetails String?
  rejectionReason   String?
  resubmissionAllowed Boolean  @default(false)
  approvedAmount    Float?
  paymentDate       DateTime?
  paymentMethod     String?
  reference         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  approvalHistory   ClaimApprovalHistory[]
  attachments       ClaimAttachment[]

  @@index([submittedByUserId])
  @@index([status])
  @@index([submissionWindow])
  @@map("sales_claims")
}

model ClaimApprovalHistory {
  id                String   @id @default(cuid())
  claimId           String
  claim             SalesClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  stage             String   // MANAGER, AVP, MD
  approvedBy        String
  approver          User @relation(fields: [approvedBy], references: [id])
  action            String   // APPROVED, REJECTED
  notes             String?
  createdAt         DateTime @default(now())

  @@index([claimId])
  @@map("claim_approval_history")
}

model ClaimAttachment {
  id                String   @id @default(cuid())
  claimId           String
  claim             SalesClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  url               String
  fileName          String
  fileType          String
  uploadedAt        DateTime @default(now())

  @@index([claimId])
  @@map("claim_attachments")
}

model SalesTarget {
  id                String   @id @default(cuid())
  userId            String
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)
  month             String   // YYYY-MM format
  callsTarget       Int      @default(0)
  visitsTarget      Int      @default(0)
  followUpsTarget   Int      @default(0)
  ordersTarget      Int      @default(0)
  collectionTarget  Float    @default(0)
  revenueTarget     Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@map("sales_targets")
}

// ─── FJP & EXPENSE APPROVAL SYSTEM ───────────────────────────────────────────

// Fixed Journey Plan — submitted by 27th of previous month
model FJP {
  id            String   @id @default(cuid())
  fjpNo         String   @unique              // e.g. FJP-2026-07-001
  userId        String
  user          User     @relation("FJPSubmissions", fields: [userId], references: [id])
  forMonth      String                        // YYYY-MM (the month the plan covers)
  submittedDate DateTime @default(now())
  status        String   @default("DRAFT")   // DRAFT, SUBMITTED, APPROVED, REJECTED
  totalDays     Int      @default(0)
  totalKm       Float    @default(0)
  estimatedCost Float    @default(0)
  notes         String?
  routes        FJPRoute[]
  expenses      ExpenseReport[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([forMonth])
  @@map("fjp")
}

// Individual route/day entries in the FJP
model FJPRoute {
  id          String   @id @default(cuid())
  fjpId       String
  fjp         FJP      @relation(fields: [fjpId], references: [id], onDelete: Cascade)
  dayDate     DateTime @db.Date
  fromPlace   String
  toPlace     String
  purpose     String
  customerOrProspect String?
  estimatedKm Float    @default(0)
  modeOfTravel String  @default("Two Wheeler") // Two Wheeler, Four Wheeler, Bus, Train, Flight
  createdAt   DateTime @default(now())

  @@index([fjpId])
  @@map("fjp_routes")
}

// Expense / Travel Claim Report (replaces ad-hoc SalesClaim for structured submissions)
model ExpenseReport {
  id              String   @id @default(cuid())
  expenseNo       String   @unique             // e.g. EXP-2026-07-001
  userId          String
  user            User     @relation("ExpenseSubmissions", fields: [userId], references: [id])
  fjpId           String?                      // optional link to FJP for travel claims
  fjp             FJP?     @relation(fields: [fjpId], references: [id])
  expenseType     String                       // TRAVEL, ACCOMMODATION, FOOD, CLIENT_ENTERTAINMENT, COMMUNICATION, OTHER
  forMonth        String                       // YYYY-MM
  submittedDate   DateTime @default(now())
  description     String
  totalAmount     Float
  advanceReceived Float    @default(0)
  netPayable      Float    @default(0)         // totalAmount - advanceReceived
  status          String   @default("DRAFT")   // DRAFT, SUBMITTED, HOD_REVIEW, HOD_RECOMMENDED, HOD_HOLD, HOD_REJECTED, ACCOUNTS_VERIFY, ACCOUNTS_VERIFIED, ACCOUNTS_HOLD, CEO_REVIEW, APPROVED, REJECTED, HOLD
  holdReason      String?
  rejectionReason String?
  approvedAmount  Float?
  paymentDate     DateTime?
  paymentRef      String?
  printedAt       DateTime?
  items           ExpenseItem[]
  attachments     ExpenseAttachment[]
  approvals       ExpenseApproval[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([forMonth])
  @@map("expense_reports")
}

// Line items in an expense report
model ExpenseItem {
  id            String        @id @default(cuid())
  expenseId     String
  expense       ExpenseReport @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  date          DateTime      @db.Date
  category      String        // Fuel, Toll, Parking, Hotel, Food, Client Lunch, Train, Bus, Flight, Other
  description   String
  fromPlace     String?
  toPlace       String?
  km            Float         @default(0)
  amount        Float
  billAvailable Boolean       @default(true)
  createdAt     DateTime      @default(now())

  @@index([expenseId])
  @@map("expense_items")
}

// Uploaded proof documents for expense reports
model ExpenseAttachment {
  id          String        @id @default(cuid())
  expenseId   String
  expense     ExpenseReport @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  fileType    String        // image/jpeg, application/pdf, etc.
  uploadedAt  DateTime      @default(now())

  @@index([expenseId])
  @@map("expense_attachments")
}

// Three-tier approval chain: HOD → Accounts → CEO
model ExpenseApproval {
  id          String        @id @default(cuid())
  expenseId   String
  expense     ExpenseReport @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  stage       String        // HOD, ACCOUNTS, CEO
  actionById  String
  actionBy    User          @relation("ExpenseApprovals", fields: [actionById], references: [id])
  action      String        // RECOMMENDED, VERIFIED, APPROVED, REJECTED, HOLD
  reason      String?       // required for REJECTED or HOLD
  createdAt   DateTime      @default(now())

  @@index([expenseId])
  @@index([stage])
  @@map("expense_approvals")
}

// ─── PRODUCTION PHASE 2 ────────────────────────────────────────────────────────
// Material consumption, machine scheduling, quality control

model Machine {
  id                String   @id @default(cuid())
  machineNo         String   @unique
  name              String
  type              String   // e.g., "Printing", "Cutting", "Laminating"
  printType         String?  // For printing machines: "Cloth", "Vinyl", "Sticker", "Paper"
  model             String?
  location          String?
  status            String   @default("ACTIVE")  // ACTIVE, MAINTENANCE, RETIRED
  hourlyRate        Float    @default(0)
  capacityPerHour   Float?
  maintenanceDueAt  DateTime?
  branch            String   // TVM, KTYM, EKM, CLT
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  schedules         MachineSchedule[]
  hours             MachineHours[]
  maintenance       MachineMaintenance[]

  @@index([status])
  @@index([type])
  @@index([branch])
  @@map("machines")
}

model MachineSchedule {
  id                String   @id @default(cuid())
  scheduleNo        String   @unique
  workOrderId       String
  machineId         String
  scheduledStartAt  DateTime
  scheduledEndAt    DateTime
  actualStartAt     DateTime?
  actualEndAt       DateTime?
  estimatedOutput   Int?
  actualOutput      Int?
  operatorId        String?
  status            String   @default("SCHEDULED")  // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workOrder         WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  machine           Machine @relation(fields: [machineId], references: [id])
  operator          User? @relation(fields: [operatorId], references: [id])

  @@index([workOrderId])
  @@index([machineId])
  @@index([status])
  @@map("machine_schedules")
}

model MachineHours {
  id                String   @id @default(cuid())
  machineId         String
  date              DateTime @db.Date
  totalHours        Float    @default(8)
  productiveHours   Float    @default(0)
  downtimeHours     Float    @default(0)
  downtimeReason    String?
  performancePercent Float   @default(0)
  notes             String?
  createdAt         DateTime @default(now())

  machine           Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([date])
  @@map("machine_hours")
}

model MachineMaintenance {
  id                String   @id @default(cuid())
  maintenanceNo     String   @unique
  machineId         String
  type              String   // PREVENTIVE, CORRECTIVE, BREAKDOWN
  dueDate           DateTime
  completedAt       DateTime?
  cost              Float    @default(0)
  notes             String?
  createdAt         DateTime @default(now())

  machine           Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([type])
  @@map("machine_maintenance")
}

model MaterialConsumption {
  id                String   @id @default(cuid())
  consumptionNo     String   @unique
  workOrderId       String
  materialId        String
  plannedQty        Float
  actualQty         Float?
  wastageQty        Float    @default(0)
  unit              String   @default("units")
  costValue         Float?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workOrder         WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  material          Material @relation(fields: [materialId], references: [id])

  @@index([workOrderId])
  @@index([materialId])
  @@map("material_consumptions")
}

model QualityCheckpoint {
  id                String   @id @default(cuid())
  checkpointNo      String   @unique
  workOrderId       String
  stage             String   // PRE_PRODUCTION, MID_PRODUCTION, PRE_DELIVERY
  inspectorId       String
  checkedAt         DateTime @default(now())
  status            String   // PASS, FAIL, CONDITIONAL_PASS
  remarks           String?
  createdAt         DateTime @default(now())

  workOrder         WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  inspector         User @relation(fields: [inspectorId], references: [id])
  defects           QualityDefect[]

  @@index([workOrderId])
  @@index([stage])
  @@index([status])
  @@map("quality_checkpoints")
}

model QualityDefect {
  id                String   @id @default(cuid())
  checkpointId      String
  description       String
  severity          String   // MINOR, MAJOR, CRITICAL
  category          String   // Color, Dimension, Surface, Assembly, Alignment, etc.
  correctionRequired Boolean  @default(true)
  correctedAt       DateTime?
  notes             String?
  createdAt         DateTime @default(now())

  checkpoint        QualityCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@index([checkpointId])
  @@index([severity])
  @@map("quality_defects")
}

model ProductionRejection {
  id                String   @id @default(cuid())
  rejectionNo       String   @unique
  workOrderId       String
  reason            String
  quantity          Int
  action            String   // REWORK, SCRAP, REPLACE
  costImpact        Float    @default(0)
  approvedBy        String?
  notes             String?
  createdAt         DateTime @default(now())

  workOrder         WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  approver          User? @relation(fields: [approvedBy], references: [id])

  @@index([workOrderId])
  @@index([action])
  @@map("production_rejections")
}
